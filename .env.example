# DevPulse env template. Copy to `.env` and fill in values.
# All values below are the defaults used if not set — you only need to
# override them if your setup differs.

# Server
PORT=3000

# JWT
JWT_SECRET=devpulse-dev-secret-change-me
JWT_EXPIRES_IN=7d

# bcrypt salt rounds (8–12)
BCRYPT_ROUNDS=10

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=devpulse
DB_POOL_MAX=10
