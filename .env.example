# DevPulse env template. Copy to `.env` and fill in values.
# All values below are the defaults used if not set — you only need to
# override them if your setup differs.

# Server
PORT=3000                            # Port the Express server listens on

# JWT
JWT_SECRET=devpulse-dev-secret-change-me  # Secret key used to sign/verify tokens; change in production
JWT_EXPIRES_IN=7d                    # Token lifespan (e.g. 15m, 1h, 7d)

# bcrypt salt rounds (8–12)
BCRYPT_ROUNDS=10                     # Higher = slower hashing, more secure; keep between 8 and 12

# PostgreSQL
DB_HOST=localhost                    # Database server hostname
DB_PORT=5432                         # PostgreSQL default port
DB_USER=postgres                     # Database user
DB_PASSWORD=postgres                 # Database password
DB_NAME=devpulse                     # Database name
DB_POOL_MAX=10                       # Maximum number of connections in the pg pool
